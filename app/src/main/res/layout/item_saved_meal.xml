<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="6sp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/item_saved_meal_iv"
                android:layout_width="75dp"
                android:layout_height="75dp"/>

            <Button
                android:id="@+id/item_saved_meal_btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxHeight="0dp"
                android:maxWidth="0dp"
                android:padding="0dp"
                android:text="♥"
                android:textSize="28sp"
                android:backgroundTint="@color/primary"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10sp">

            <TextView
                android:id="@+id/item_saved_meal_tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Название"
                android:textSize="16sp"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:columnCount="6"
                android:rowCount="2">

                <TextView
                    android:id="@+id/item_saved_meal_tv_proteins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="0"
                    android:layout_columnWeight="0"
                    android:text="Б: "
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_proteins_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:text="0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_fats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="2"
                    android:layout_columnWeight="0"
                    android:text="Ж: "
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_fats_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="3"
                    android:layout_columnWeight="1"
                    android:text="0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_carbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="4"
                    android:layout_columnWeight="0"
                    android:text="У: "
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_carbs_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="5"
                    android:layout_columnWeight="1"
                    android:text="0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_calories_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textAlignment="viewEnd"
                    android:layout_column="2"
                    android:layout_columnSpan="3"
                    android:layout_columnWeight="2"
                    android:layout_row="1"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/item_saved_meal_tv_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:layout_row="1"
                    android:layout_column="5"
                    android:layout_columnWeight="1"
                    android:text="ккал"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>