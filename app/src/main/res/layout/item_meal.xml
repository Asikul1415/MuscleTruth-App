<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/surface">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:rowCount="2"
        android:columnCount="1">

        <TextView
            android:id="@+id/item_meal_tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_row="0"
            android:text="Дата и время"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:rowCount="1"
            android:columnCount="8">

            <TextView
                android:id="@+id/item_meal_tv_proteins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary"
                android:layout_column="0"
                android:layout_columnWeight="0"
                android:text="Б:" />

            <TextView
                android:id="@+id/item_meal_tv_proteins_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:text="0" />

            <TextView
                android:id="@+id/item_meal_tv_fats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary"
                android:layout_column="2"
                android:layout_columnWeight="0"
                android:text="Ж:" />

            <TextView
                android:id="@+id/item_meal_tv_fats_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:layout_column="3"
                android:layout_columnWeight="1"
                android:text="0" />

            <TextView
                android:id="@+id/item_meal_tv_carbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary"
                android:layout_column="4"
                android:layout_columnWeight="0"
                android:text="У:" />

            <TextView
                android:id="@+id/item_meal_tv_carbs_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:layout_column="5"
                android:layout_columnWeight="1"
                android:text="0" />

            <TextView
                android:id="@+id/item_meal_tv_calories_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:layout_column="6"
                android:layout_columnWeight="1"
                android:text="0" />

            <TextView
                android:id="@+id/item_meal_tv_calories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary"
                android:layout_column="7"
                android:layout_columnWeight="0"
                android:text="ккал" />
        </GridLayout>
    </GridLayout>


</LinearLayout>