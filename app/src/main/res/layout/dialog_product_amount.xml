<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp"
        android:columnCount="3"
        android:rowCount="6"
        android:orientation="horizontal">

        <TextView
            android:id="@id/dg_product_amount_tv_product_title"
            android:text="Название продукта"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_row="0"
            android:layout_columnSpan="3"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            />

        <!-- Row 1: Proteins -->
        <TextView
            android:text="Б:"
            android:textSize="24sp"
            android:layout_width="100dp"
            android:layout_column="0"
            android:layout_row="1"
            android:layout_gravity="start|center_vertical" />

        <GridLayout
            android:layout_row="1"
            android:layout_columnSpan="2"
            android:layout_gravity="center">

            <TextView
                android:id="@+id/dg_product_amount_tv_proteins_val"
                android:text="0"
                android:textAlignment="center"
                android:textSize="24sp"
                android:layout_column="0"
                android:layout_row="0"/>

            <TextView
                android:layout_width="65dp"
                android:text="г"
                android:textSize="24sp"
                android:layout_column="1"
                android:layout_row="0"
                android:layout_gravity="" />
        </GridLayout>

        <!-- Row 2: Fats -->
        <TextView
            android:text="Ж:"
            android:layout_width="100dp"
            android:textSize="24sp"
            android:layout_column="0"
            android:layout_row="2"
            android:layout_gravity="start|center_vertical" />

        <GridLayout
            android:layout_row="2"
            android:layout_columnSpan="2"
            android:layout_gravity="center">

            <TextView
                android:id="@+id/dg_product_amount_tv_fats_val"
                android:text="0"
                android:textAlignment="center"
                android:textSize="24sp"
                android:layout_column="1"
                android:layout_row="1" />

            <TextView
                android:layout_width="65dp"
                android:text="г"
                android:textSize="24sp"
                android:layout_column="2"
                android:layout_row="1"
                android:layout_gravity="start|center_vertical" />
        </GridLayout>

        <!-- Row 3: Carbs -->
        <TextView
            android:text="У:"
            android:layout_width="100dp"
            android:textSize="24sp"
            android:layout_column="0"
            android:layout_row="3"
            android:layout_gravity="start|center_vertical" />

        <GridLayout
            android:layout_row="3"
            android:layout_columnSpan="2"
            android:layout_gravity="center">

            <TextView
                android:id="@+id/dg_product_amount_tv_carbs_val"
                android:text="0"
                android:textAlignment="center"
                android:textSize="24sp"
                android:layout_column="1"
                android:layout_row="2"/>

            <TextView
                android:layout_width="65dp"
                android:text="г"
                android:textSize="24sp"
                android:layout_column="2"
                android:layout_row="2"
                android:layout_gravity="start|center_vertical" />
        </GridLayout>

        <GridLayout
            android:layout_row="4"
            android:layout_column="1"
            android:layout_columnSpan="2"
            android:layout_gravity="center">

            <!-- Row 4: Calories (span across all 3 columns) -->
            <TextView
                android:id="@+id/dg_product_amount_tv_calories_val"
                android:text="0"
                android:textAlignment="center"
                android:textSize="24sp"
                android:layout_column="0"
                android:layout_row="0"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="65dp"
                android:text="ккал"
                android:textSize="24sp"
                android:layout_column="1"
                android:layout_row="0"
                android:layout_gravity="start|center_vertical" />
        </GridLayout>

        <GridLayout
            android:layout_row="5"
            android:layout_columnSpan="3"
            android:layout_gravity="center"
            android:columnCount="2">

            <EditText
                android:id="@+id/dialog_product_amount_et_amount"
                android:inputType="number"
                android:text=""
                android:textAlignment="center"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_gravity="center" />

            <TextView
                android:text="г"
                android:textSize="24sp"
                android:layout_column="1"
                android:layout_gravity="center|center_vertical" />
        </GridLayout>
    </GridLayout>
</ScrollView>