<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MuscleTruthApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:screenOrientation="portrait"
        android:supportsRtl="true"
        android:theme="@style/Theme.MuscleTruth"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ui.Meals.SavedMealsActivity"
            android:exported="false"
            android:theme="@style/Theme.MuscleTruth" />
        <activity
            android:name=".ui.StatisticActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Meals.MealActivity"
            android:exported="false" />
        <activity
            android:name=".ui.User.ChangeProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Meals.MealsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Servings.AddServingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Weightings.WeightingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Weightings.WeightingsActivity"
            android:exported="false"
            android:theme="@style/Theme.MuscleTruth" />
        <activity
            android:name=".ui.User.MyProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Products.AddProductActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Meals.AddMealActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Weightings.AddWeightingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.MainMenuActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Auth.AuthorizationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Auth.RegistrationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.EnterActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>